rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Check if the user is a super-admin (sibhi.gv@gmail.com)
    function isSuperAdmin() {
      return request.auth != null && request.auth.token.email == "sibhi.gv@gmail.com";
    }

    // Helper: Check if the user has admin role in their user document
    // NOTE: Simplified to avoid circular dependency for new users
    function isAdmin() {
      return request.auth != null && 
        (isSuperAdmin() || 
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin"));
    }

    // Helper: Check if the user can edit fertigation
    function canEditFertigation() {
      return request.auth != null && 
        (isAdmin() || 
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.canEditFertigation == true));
    }

    // 1. Users Collection Rules
    match /users/{userId} {
      // ✅ BROADENED READ: Users can ALWAYS read their own UID doc without needing isAdmin check
      // This prevents the "permission denied" when first syncing/checking their own doc.
      allow read: if request.auth != null && (request.auth.uid == userId || isSuperAdmin() || isAdmin());
      
      // Allow creation of own profile
      allow create: if request.auth != null && request.auth.uid == userId;
      
      // Admins can update roles; Users can only update their basic info
      allow update: if request.auth != null && (
        (request.auth.uid == userId && 
         !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'canEditFertigation'])) 
        || isSuperAdmin() || isAdmin()
      );
      allow delete: if isSuperAdmin() || isAdmin();
    }

    // 2. Irrigation Devices & Logs (Read-only for all signed-in users)
    match /irrigation_devices/{deviceId} {
      allow read: if request.auth != null;
    }
    match /irrigation_devices/{deviceId}/{allPaths=**} {
      allow read: if request.auth != null;
    }

    // 3. Fertigation Queue & Valve Groups (Restricted Writes)
    match /irrigation_devices/{deviceId}/fertigation_queue/{docId} {
      allow write: if canEditFertigation();
    }
    match /irrigation_devices/{deviceId}/valve_groups/{docId} {
      allow write: if canEditFertigation();
    }
    
    // Legacy support for the old Users doc
    match /irrigation_devices/Users {
      allow read: if request.auth != null;
      allow write: if isSuperAdmin();
    }
  }
}